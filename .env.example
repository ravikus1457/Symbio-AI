# Brain Council — local secrets. Copy this file to `.env` and paste your key.
#   cp .env.example .env   then edit .env
#
# `.env` is gitignored, so your real key is never committed. The council CLI
# (`node scripts/council.mjs` / `npm run council`) loads it automatically.
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=
