---
layout: base.njk
pageKey: home
description: Symbio AI is a web design studio for small businesses. We design fast, modern websites, plus custom apps, dashboards, chatbots, and AI agents. Start with a free scan, no commitment.
---

{# ===== Living hero ===================================================== #}
<section class="hero">
  <div class="hero__aurora" aria-hidden="true"></div>
  <div class="container">
    <div class="hero__grid">
      <div class="hero__content">
        <span class="hero__pill">
          <span class="hero__pill-dot" aria-hidden="true"></span>
          Booking new website projects
        </span>

        <h1 class="hero__title">
          Websites that turn visitors into
          <span
            class="hero__rotator"
            data-rotator
            data-words="customers,bookings,regulars,revenue"
          >
            <span class="hero__rotator-word">customers</span></span
          >.
        </h1>

        <p class="hero__lead">
          {{ site.positioning }} Built around how you actually run things, so you stay in control.
        </p>

        <div class="hero__cta btn-row">
          <a class="btn btn--primary btn--lg" href="{{ site.cta.url }}">Get my free scan</a>
          <a class="btn btn--ghost btn--lg" href="{{ site.links.demos }}">See the live demos</a>
        </div>

        <p class="hero__note">
          No commitment. We scan your current site and reply with what’s working, what isn’t, and
          what we’d build first.
        </p>
      </div>

      {# A clean browser mock-up sells the web design itself. The live "lead
         inbox" floats on top as the system we install — main.js animates it;
         the static markup is the no-JS / reduced-motion fallback. #}
      <div class="hero__showcase" aria-label="A website built by Symbio AI, with live lead capture">
        <div class="browser" aria-hidden="true">
          <div class="browser__bar">
            <span class="browser__dots"><i></i><i></i><i></i></span>
            <span class="browser__url">yourbusiness.com</span>
          </div>
          <div class="browser__screen">
            <div class="mini">
              <div class="mini__nav">
                <span class="mini__logo"></span>
                <span class="mini__links"><i></i><i></i><i></i></span>
                <span class="mini__cta">Book</span>
              </div>
              <div class="mini__body">
                <div class="mini__copy">
                  <span class="mini__eyebrow">Fresh, local, daily</span>
                  <span class="mini__headline">Fresh pasta,<br />made daily.</span>
                  <span class="mini__sub">Hand-rolled and served from 5pm.</span>
                  <span class="mini__btn">Reserve a table</span>
                </div>
                <div class="mini__media" aria-hidden="true"></div>
              </div>
            </div>
          </div>
        </div>

        <aside class="lead-inbox lead-inbox--float" aria-label="Example live lead inbox">
          <div class="lead-inbox__bar">
            <span class="lead-inbox__title">
              <span class="lead-inbox__live" aria-hidden="true"></span>
              Lead inbox
            </span>
            <span class="lead-inbox__count">
              <strong data-inbox-count>27</strong> today
            </span>
          </div>

          <ul class="lead-inbox__list" data-inbox>
            <li class="lead">
              <span class="lead__avatar" aria-hidden="true">JM</span>
              <span class="lead__body">
                <span class="lead__name">Jordan M.</span>
                <span class="lead__msg">Do you take new patients this week?</span>
              </span>
              <span class="badge badge--booked">Booked</span>
            </li>
            <li class="lead">
              <span class="lead__avatar" aria-hidden="true">SR</span>
              <span class="lead__body">
                <span class="lead__name">Sarah R.</span>
                <span class="lead__msg">Can I get a quote for a kitchen remodel?</span>
              </span>
              <span class="badge badge--replied">Replied</span>
            </li>
            <li class="lead">
              <span class="lead__avatar" aria-hidden="true">AT</span>
              <span class="lead__body">
                <span class="lead__name">Alex T.</span>
                <span class="lead__msg">Are you open this Saturday?</span>
              </span>
              <span class="badge badge--booked">Booked</span>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </div>
</section>

{# ===== Who we help (slim strip) ====================================== #}
<section class="section section--tight">
  <div class="container">
    <p class="audience" data-reveal>
      <span class="audience__label">Built for</span>
      {% for who in site.whoWeHelp %}
        <span class="chip">{{ who }}</span>
      {% endfor %}
    </p>
  </div>
</section>

