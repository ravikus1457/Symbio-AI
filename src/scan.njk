---
layout: base.njk
pageKey: scan
title: Free scan
permalink: scan.html
description: Get a free scan of your website. Tell us your link and we’ll reply with what’s leaking leads and the first fix we’d make. No commitment.
---

{# ===== Page head ====================================================== #}
<section class="section section--tight">
  <div class="container container--narrow center">
    <span class="eyebrow eyebrow--center">Free scan</span>
    <h1 class="section__title">See what your site is leaking — free.</h1>
    <p class="section__lead">
      Tell us a bit about your business and drop your link. We’ll reply with the leaks we spot
      and the first fix we’d make — no commitment, no pressure.
    </p>
  </div>
</section>

{# ===== Form + contact =============================================== #}
<section class="section section--tight">
  <div class="container">
    <div class="grid grid--2 grid--top">
      {# --- The conversion form. main.js posts it as JSON; falls back to mailto. --- #}
      <div class="card" data-reveal>
        <h2 class="card__title">Request your free scan</h2>
        <p class="card__text">Fields marked <span aria-hidden="true">*</span> are required.</p>

        <form class="form mt-6" data-scan-form novalidate>
          <div class="form-grid form-grid--2">
            <div class="field">
              <label class="field__label" for="scan-name">Your name *</label>
              <input class="input" id="scan-name" name="name" type="text" autocomplete="name" required />
            </div>
            <div class="field">
              <label class="field__label" for="scan-business">Business name</label>
              <input class="input" id="scan-business" name="business" type="text" autocomplete="organization" />
            </div>
            <div class="field">
              <label class="field__label" for="scan-email">Email *</label>
              <input class="input" id="scan-email" name="email" type="email" autocomplete="email" required />
            </div>
            <div class="field">
              <label class="field__label" for="scan-phone">Phone</label>
              <input class="input" id="scan-phone" name="phone" type="tel" autocomplete="tel" />
            </div>
            <div class="field field--full">
              <label class="field__label" for="scan-link">
                Your website or social link
                <span class="field__hint">— so we can scan it</span>
              </label>
              <input class="input" id="scan-link" name="link" type="url" inputmode="url" placeholder="https://" />
            </div>
            <div class="field">
              <label class="field__label" for="scan-need">What do you need?</label>
              <select class="select" id="scan-need" name="need">
                <option value="">Choose one…</option>
                <option>Website</option>
                <option>Redesign</option>
                <option>Custom app</option>
                <option>AI chatbot</option>
                <option>Booking system</option>
                <option>Automation</option>
                <option>Not sure yet</option>
              </select>
            </div>
            <div class="field">
              <label class="field__label" for="scan-budget">Rough budget</label>
              <select class="select" id="scan-budget" name="budget">
                <option value="">Choose one…</option>
                <option>Under $2,000</option>
                <option>$2,000 – $5,000</option>
                <option>$5,000+</option>
                <option>Not sure yet</option>
              </select>
            </div>
            <div class="field field--full">
              <label class="field__label" for="scan-goal">What’s the goal?</label>
              <input class="input" id="scan-goal" name="goal" type="text" placeholder="e.g. more booked calls, fewer no-shows" />
            </div>
            <div class="field field--full">
              <label class="field__label" for="scan-problem">What’s the main problem right now?</label>
              <textarea class="textarea" id="scan-problem" name="problem" placeholder="Tell us what feels broken or slow."></textarea>
            </div>
          </div>

          {# Filled with the current page URL by main.js before submit. #}
          <input type="hidden" name="sourceUrl" data-source-url value="" />

          <div class="btn-row">
            <button class="btn btn--primary btn--lg" type="submit" data-scan-submit>
              Send my free scan request
            </button>
          </div>

          <p class="form__status" data-scan-status role="status" aria-live="polite"></p>
        </form>
      </div>

      {# --- Direct contact + what to expect --- #}
      <aside class="founder" data-reveal data-reveal-delay="1">
        <h2 class="founder__name">Prefer to just talk?</h2>
        <p class="card__text">Reach the builders directly — you’ll hear back from a real person.</p>

        <div class="founder__contact mt-6">
          {% for person in site.founders %}
            <p class="site-footer__person">{{ person.name }} <span class="founder__role">· {{ person.role }}</span></p>
            <a href="mailto:{{ person.email }}">✉ {{ person.email }}</a>
            {% if person.phone %}
              <a href="tel:{{ person.phone | replace(r/[^0-9+]/g, '') }}">☎ {{ person.phone }}</a>
            {% endif %}
          {% endfor %}
        </div>

        <hr class="founder__rule" />

        <h3 class="proof__title">What you’ll get</h3>
        <ul class="card__list">
          <li>A quick read on where your site leaks leads</li>
          <li>The single fix we’d make first</li>
          <li>A rough, honest price range — no obligation</li>
        </ul>
      </aside>
    </div>
  </div>
</section>
