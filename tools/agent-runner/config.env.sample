# Symbio Agent Runner — config. Copy to config.env (gitignored).
# systemd loads this via EnvironmentFile=; the script also auto-loads ./config.env.

# --- Telegram control + approvals (optional but recommended) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Heartbeat / uptime ---
RUNNER_HEARTBEAT_SEC=900
# Ping this URL on each heartbeat so you're alerted if the Pi dies
# (e.g. a https://healthchecks.io check):
# RUNNER_HEALTHCHECK_URL=

# --- Backups (SQLite state copied here, pruned to KEEP newest) ---
# RUNNER_BACKUP_PATHS=/home/pi/symbio/tools/agent-runner/runner.db,/home/pi/symbio/tools/lead-engine/leads.db
# RUNNER_BACKUP_DIR=/home/pi/symbio/backups
# RUNNER_BACKUP_KEEP=14

# --- Webhook receiver (optional; 0 = off). Pair with a Cloudflare tunnel to
#     expose it, then POST /hook/<job>?token=SECRET to trigger a job from Stripe,
#     a form, GitHub, etc. GET /health returns the last heartbeat. ---
# RUNNER_WEBHOOK_PORT=8970
# RUNNER_WEBHOOK_SECRET=change-me-long-random

# --- Tuning ---
RUNNER_TICK_SEC=30

# --- Inherited by jobs (so the lead engine / free scan see them) ---
# ANTHROPIC_API_KEY=
# SYMBIO_SENDER_NAME=Ravi
# SYMBIO_BRAND=Symbio AI
# SYMBIO_CONTACT=ravikus1457@gmail.com
