# Symbio Lead Engine — config
# Copy to config.env and fill in. (config.env is gitignored.)
# systemd loads this via EnvironmentFile=; the script also auto-loads ./config.env.

# --- Who the outreach is from (used in drafts; required for CAN-SPAM identity) ---
SYMBIO_SENDER_NAME=Ravi
SYMBIO_BRAND=Symbio AI
SYMBIO_CONTACT=ravikus1457@gmail.com
# SYMBIO_SITE=https://your-symbio-site.example
SYMBIO_OFFER=a free 2-minute scan of your online presence

# --- Optional: Claude drafting (used only with `ingest --llm`) ---
# ANTHROPIC_API_KEY=sk-ant-...
# LEADENGINE_MODEL=claude-opus-4-8

# --- Optional: Google Places source (`ingest --source places`) ---
# Using the Places API is subject to Google's Terms of Service.
# PLACES_API_KEY=

# --- Optional: Telegram notifications + phone approvals ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Optional: timer entrypoint (`run`) ingests this seed each fire ---
# LEADENGINE_SEED_CSV=/home/pi/symbio/lead-engine/seeds/prospects.csv

# --- Paths (sensible defaults; override if you like) ---
# LEADENGINE_DB=/home/pi/symbio/lead-engine/leads.db
# LEADENGINE_OUTBOX=/home/pi/symbio/lead-engine/outbox
# LEADENGINE_HTTP_TIMEOUT=7
